# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environment ────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Distribution / packaging ───────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/

# ── Testing ────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── ML model binaries (large, regenerated by pipeline) ────────────────
models/*.pkl
models/*.joblib
# Keep JSON metadata files
!models/*.json

# ── Raw data (never commit real customer data) ─────────────────────────
data/raw/
# Keep synthetic data and processed outputs
!data/synthetic/
!data/processed/

# ── Reports output (generated PDFs) ───────────────────────────────────
reports/output/

# ── Jupyter ────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE / OS ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Environment variables / secrets ───────────────────────────────────
.env
.env.*
*.env
secrets.yaml
credentials.json

# ── Logs ──────────────────────────────────────────────────────────────
*.log
logs/

# ── Temp files ────────────────────────────────────────────────────────
*.tmp
*.temp
tmp/
